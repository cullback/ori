import Bool
import List
import Str
import Result

# Advent of Code 2015, Day 1: Not Quite Lisp

part1 : Str -> I64
part1 = |input| input
        .to_utf8()
        .walk(0, |count, x|
            count + if x == '(' then 1
            else if x == ')' then -1
            else 0
        )

main : List(Str), Str -> Result(Str, Str)
main = |args, input| (
    Ok(part1(input).to_str())
)
