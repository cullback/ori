exports [I16]

I16 := {}.(
    add : I16, I16 -> I16
    sub : I16, I16 -> I16
    mul : I16, I16 -> I16
    div : I16, I16 -> I16
    mod : I16, I16 -> I16
    equals : I16, I16 -> Bool
    compare : I16, I16 -> Order
    to_str : I16 -> Str

    min : I16, I16 -> I16
    min = |a, b| if a <= b then a else b

    max : I16, I16 -> I16
    max = |a, b| if a >= b then a else b
)
