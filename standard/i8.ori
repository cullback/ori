exports [I8]

I8 := {}.(
    add : I8, I8 -> I8
    sub : I8, I8 -> I8
    mul : I8, I8 -> I8
    div : I8, I8 -> I8
    mod : I8, I8 -> I8
    equals : I8, I8 -> Bool
    compare : I8, I8 -> Order
    to_str : I8 -> Str

    min : I8, I8 -> I8
    min = |a, b| if a <= b then a else b

    max : I8, I8 -> I8
    max = |a, b| if a >= b then a else b
)
