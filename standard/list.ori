// List is a built-in vector-backed type.
// walk, map, len, get, append, reverse, and empty are compiler builtins.
// Everything else is implemented here using those primitives.

sum : List(I64) -> I64
sum = |xs| List.walk(xs, 0, |acc, x| acc + x)

length : List(a) -> I64
length = |xs| List.len(xs)
