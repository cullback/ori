exports [Result]

# A value that is either a success or a failure.
Result(ok, err) := [Ok(ok), Err(err)].(
    # Extracts the Ok value, or crashes on Err.
    unwrap : Result(ok, err) -> ok
    unwrap = |r| if r
        : Ok(val) then val
        else crash("called unwrap on Err")

    # Transforms the error value, leaving Ok unchanged.
    map_err : Result(ok, a), (a -> b) -> Result(ok, b)
    map_err = |r, f| if r
        : Ok(val) then Ok(val)
        : Err(e) then Err(f(e))
)
